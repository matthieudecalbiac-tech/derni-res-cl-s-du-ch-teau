# ===========================================================================
# Variables d'environnement (Vite)
# ===========================================================================

# ───────────────────────────────────────────────────────────────────────────
# Supabase — projet lcc-prod (eu-west-1, Ireland)
# ───────────────────────────────────────────────────────────────────────────
# Project ref : ynoieryxfqiqjscqieum
#
# VITE_SUPABASE_URL     : URL projet (publique, présente dans le bundle).
# VITE_SUPABASE_ANON_KEY: clé publique anon (RLS protège les données).
#
# NE JAMAIS commit la clé service_role (bypass RLS) — usage serveur only.
# Récupérer les clés sur : Dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://ynoieryxfqiqjscqieum.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...REPLACE_WITH_YOUR_ANON_KEY

# ───────────────────────────────────────────────────────────────────────────
# DEV ONLY — Simulation latence Supabase
# ───────────────────────────────────────────────────────────────────────────
# Active une latence artificielle (en ms) sur les fonctions async du
# service chateauxService.js, pour tester les loading states en dev.
#
# Phase 2.3 (4 mai 2026) : services rendus async pour préparer le swap
# statique → Supabase. Cette variable simule la latence réseau réelle.
#
# Usage : VITE_FAKE_LATENCY=300 npm run dev
#
# Désactivée par défaut (0 = pas de latence) — sécurise la prod.
VITE_FAKE_LATENCY=
